# Copy this file to a local-only `.env` file.
# Never commit real credentials to git.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Remote bridge protection
DRAGON_BRIDGE_TOKEN=CHANGE_ME_LONG_RANDOM_TOKEN
DRAGON_ALLOW_INSECURE_REMOTE=0
DRAGON_ALLOWED_ORIGINS=https://admin.example.com,https://kassa.example.com

# Cashier login baseline
DRAGON_KASSA_PIN=CHANGE_ME_STRONG_PIN

# Purchase order app baseline
DRAGON_PO_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DRAGON_PO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
DRAGON_PO_SECURE_COOKIE=1

# LiqPay checkout (server-side only)
# DRAGON_LIQPAY_PUBLIC_KEY=
# DRAGON_LIQPAY_PRIVATE_KEY=
# DRAGON_LIQPAY_RESULT_URL=https://example.com/payment/result
# DRAGON_LIQPAY_SERVER_URL=https://example.com/api/payment/webhook
# DRAGON_LIQPAY_SANDBOX=0

# Optional overrides
# SUPABASE_ORDERS_TABLE=orders
# SUPABASE_MENU_STATE_TABLE=menu_state
# SUPABASE_MENU_SCOPE=global

# Stable remote address via named Cloudflare Tunnel
# DLV_TUNNEL_NAME=dlv-restaurant
# DLV_PUBLIC_HOSTNAME=dlv.example.com
# DLV_PUBLIC_BRIDGE_URL=https://dlv.example.com
# CLOUDFLARED_EDGE_IP_VERSION=4

# Optional Telegram notification when quick tunnel URL changes
# DRAGON_TG_BOT_TOKEN=123456:telegram-bot-token
# DRAGON_TG_CHAT_ID=-1001234567890
# DRAGON_TG_CHAT_IDS=-1001234567890,-1009876543210

# Optional localhost.run external tunnel
# DLV_LOCALHOSTRUN_LOGIN=nokey@localhost.run
# DLV_LOCALHOSTRUN_DOMAIN=
# DLV_LOCALHOSTRUN_SERVER_ALIVE=30
